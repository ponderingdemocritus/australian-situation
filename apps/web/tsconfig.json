{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "baseUrl": ".",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "allowJs": false,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "isolatedModules": true,
    "paths": {
      "@aus-dash/ui/components/*": [
        "../../packages/ui/src/components/*"
      ],
      "@aus-dash/ui/hooks/*": [
        "../../packages/ui/src/hooks/*"
      ],
      "@aus-dash/ui/lib/*": [
        "../../packages/ui/src/lib/*"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "@aus-dash/**/*"
  ]
}
