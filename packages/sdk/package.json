{
  "name": "@aus-dash/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the AUS Dash API",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm && tsc -p tsconfig.build.json",
    "check": "bun scripts/check-generated.ts",
    "generate": "openapi-ts -f openapi-ts.config.ts",
    "prepack": "bun run build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@hey-api/client-fetch": "0.13.1",
    "@hey-api/openapi-ts": "0.94.0",
    "typescript": "^5.9.3",
    "vitest": "2.1.9"
  }
}
